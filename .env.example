# ---- Email (SMTP) settings ----
# Copy this file to ".env" and fill in your real values.
#
# Example for Gmail / Google Workspace:
#   1. Turn on 2-Step Verification on the account.
#   2. Create an "App Password" (Google Account > Security > App passwords).
#   3. Use that 16-character app password as SMTP_PASS below.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-address@example.com
SMTP_PASS=your-app-password-here

# What recipients see in the "From" field
FROM_NAME=Trilegal
FROM_EMAIL=your-address@example.com

# Optional: send a blind copy of every submission to this address (leave blank to disable)
BCC_EMAIL=

# ---- Brevo (recommended for hosts that block SMTP, e.g. Render free tier) ----
# If set, email is sent via Brevo's HTTPS API instead of SMTP (still from FROM_EMAIL,
# still with the PDF attached). Get a key at https://app.brevo.com (SMTP & API > API Keys)
# and verify FROM_EMAIL as a sender. Leave blank to use SMTP above.
BREVO_API_KEY=

# Port the web server runs on
PORT=3000
